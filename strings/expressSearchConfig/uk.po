#. Used in: 
msgid "CollObjToDeterminer"
msgstr "Об'єкт Колекції Таксону"

#. Used in: 
msgid "CollObjToDeterminer_desc"
msgstr ""
"Колекції об'єктів з поточним визначенням, відображають визначену назву "
"таксону, звичайну назві таксону, та визначення."

#. Used in: 
msgid "CollObToLocality"
msgstr "Збирання Місцевості Події"

#. Used in: 
msgid "CollObToLocality_desc"
msgstr ""
"Збирання подій та їх місцевості, включаючи дати подій та географічні "
"координати."

#. Used in: 
msgid "CollObject"
msgstr "Таксон Об'єкт Колекції"

#. Used in: 
msgid "CollObject_desc"
msgstr "Об'єкти колекції з їх визначеними назвами таксону."

#. Used in: 
msgid "GeoToTaxon"
msgstr "Географія Таксону"

#. Used in: 
msgid "GeoToTaxon_desc"
msgstr ""
"Таксони з'єднані географічними записами через визначення об'єкту колекції та "
"збирання місцевості події."

#. Used in: 
msgid "ColObjCollectors"
msgstr "Збирачі Об'єктів Колекції"

#. Used in: 
msgid "ColObjCollectors_desc"
msgstr "Об'єкти колекції та агенти які зібрали їх, з датами збирання події."

#. Used in: 
msgid "AcceptedTaxon"
msgstr "Таксон Бажаного Таксону"

#. Used in: 
msgid "AcceptedTaxon_desc"
msgstr ""
"Таксони з бажаними прийнятими назвами таксону, виключаючи записи в яких "
"відсутнє прийняте з'єднання таксону."

#. Used in: 
msgid "SynonymCollObjs"
msgstr "Об'єкт Колекції Бажаного Таксону"

#. Used in: 
msgid "SynonymCollObjs_desc"
msgstr ""
"Об'єкти колекції з визначеннями які мають обидва оригінальний таксон та "
"бажаний таксон."

#. Used in: 
msgid "OtherSynsCollObjs"
msgstr "Збирання Таксон Об'єктів (всі синоніми)"

#. Used in: 
msgid "OtherSynsCollObjs_desc"
msgstr ""
"Об'єкти колекцій які відображають визначення, бажані назви таксонів, та "
"прийняті синоніми дочірніх назв."

#. Used in: 
msgid "CurrCollObject"
msgstr "Об'єкт Колекції Таксон (визначений)"

#. Used in: 
msgid "CurrCollObject_desc"
msgstr "Об'єкти колекцій з їх поточним тільки визначенням таксону."

#. Used in: 
msgid "AgentFromAgentVariant"
msgstr "Агент Варіант Агенту"

#. Used in: 
msgid "AgentFromAgentVariant_desc"
msgstr "Варіанти агентів зіставлені парами з їх записами предків агенту."

#. Used in: 
msgid "Agent"
msgstr "Агент"

#. Used in: 
msgid "Agent_desc"
msgstr "Індивідуальні агенти."

#. Used in: 
msgid "AgentVariant"
msgstr "Варіанти Агенту"

#. Used in: 
msgid "AgentVariant_desc"
msgstr "Записи варіанту агенту."

#. Used in: 
msgid "LocalityAlias"
msgstr "Місцевість Псевдонім Місцевості"

#. Used in: 
msgid "LocalityAlias_desc"
msgstr "Записи місцевості з асоційованими псевдонімами назв місцевості."

#. Used in: 
msgid "CEToCO"
msgstr "Об'єкт Колекції Збирає Подію"

#. Used in: 
msgid "CEToCO_desc"
msgstr "Зібрані події з'єднані до об'єктів колекції."

#. Used in: 
msgid "LocToCO"
msgstr "Колекція Місцевість Об'єкту"

#. Used in: 
msgid "LocToCO_desc"
msgstr "Місцевості та об'єкти колекції знайдені в їх зібраних подіях."

#. Used in: 
msgid "AccessionToCo"
msgstr "Об'єкт Колекції Приєднання"

#. Used in: 
msgid "AccessionToCo_desc"
msgstr "Приєднання та їх об'єкти колекції, з фільтровані до поточних визначень."

#. Used in: 
msgid "AccessionToAgent"
msgstr "Агент Приєднання"

#. Used in: 
msgid "AccessionToAgent_desc"
msgstr ""
"Приєднання та агенти асоційовані за допомогою ролей агенту з приєднання."

#. Used in: 
msgid "BorrowToAgent"
msgstr "Агент Позичення"

#. Used in: 
msgid "BorrowToAgent_desc"
msgstr "Позичає та агенти з'єднанні через позичання ролей агента."

#. Used in: 
msgid "AppraisalToAgent"
msgstr "Оцінка Агента"

#. Used in: 
msgid "AppraisalToAgent_desc"
msgstr "Оцінювання та їх асоційовані агенти."

#. Used in: 
msgid "GeoTimePeriodToCO"
msgstr "Об'єкт Колекції Хроностратиграфії"

#. Used in: 
msgid "GeoTimePeriodToCO_desc"
msgstr ""
"Геологічний період часу з колекцією об'єктів з'єднаних через "
"хроностратиграфічні вмісти."

#. Used in: 
msgid "CollEventToCollectors"
msgstr "Збирач Збирання Події"

#. Used in: 
msgid "CollEventToCollectors_desc"
msgstr "Збирання подій, які зроблені парами з агентами які зібрали зразки."

#. Used in: 
msgid "AgentExchangeIn"
msgstr "Вхідний Обмін Агенту"

#. Used in: 
msgid "AgentExchangeIn_desc"
msgstr "Вхідні обміни та агенти від яких отримали матеріал."

#. Used in: 
msgid "AgentExchangeOut"
msgstr "Вихідний Обмін Агенту"

#. Used in: 
msgid "AgentExchangeOut_desc"
msgstr "Вихідні обміни та агенти до яких відправили матеріал."

#. Used in: 
msgid "GeographyCE"
msgstr "Географія Події Збирання"

#. Used in: 
msgid "GeographyCE_desc"
msgstr "Події збирання з географічною областю місцевості кожної події."

#. Used in: 
msgid "GeographyCO"
msgstr "Географічний Об'єкт Колекції"

#. Used in: 
msgid "GeographyCO_desc"
msgstr ""
"Об'єкти колекції з'єднані до географічних областей їх місцевості події "
"збирання."

#. Used in: 
msgid "GiftCO"
msgstr "Об'єкт Колекції Подарунок"

#. Used in: 
msgid "GiftCO_desc"
msgstr "Подарунки з колекцією об'єктів прикріплених до приготувань подарунку."

#. Used in: 
msgid "GiftAgent"
msgstr "Агент Подарунку"

#. Used in: 
msgid "GiftAgent_desc"
msgstr "Подарунки та агенти пов'язані з цими подарунками."

#. Used in: 
msgid "LoanCO"
msgstr "Об'єкт Колекції Позика"

#. Used in: 
msgid "LoanCO_desc"
msgstr "Позики з об'єктами колекції по підготовці позик."

#. Used in: 
msgid "LoanAgent"
msgstr "Агент Позики"

#. Used in: 
msgid "LoanAgent_desc"
msgstr "Позики та агенти залучені через ролі агентів позики."

#. Used in: 
msgid "LithoStratToCO"
msgstr "Об'єкт Колекції Літостратиграфічний"

#. Used in: 
msgid "LithoStratToCO_desc"
msgstr ""
"Літостратиграфічні одиниці та колекції об'єктів пов'язані через стосунки "
"палео-змісту."

#. Used in: 
msgid "PermitToCO"
msgstr "Об'єкт Колекції Дозвіл"

#. Used in: 
msgid "PermitToCO_desc"
msgstr ""
"Дозволяє та збирає об'єкти пов'язані через приєднання авторизованих стосунків"
"(зв'язків)."

